# Copy this file to `.env` and fill in the values.   cp .env.example .env
#
# NOTE: keep this file ASCII-only. slowapi reads `.env` through starlette Config,
# which decodes it with the system locale (cp949 on Korean Windows) -- non-ASCII
# comments crash the app at import time. Korean explanations live in README.md.

# --- Database ---
# Production stack: PostgreSQL (asyncpg driver). Matches docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prober

# Quick local smoke test without Postgres (auth paths only, no pgvector):
# DATABASE_URL=sqlite+aiosqlite:///./prober_dev.db

# --- JWT ---
# Replace with a long random value in production (e.g. openssl rand -hex 32)
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- App ---
APP_NAME=Prober

# --- LLM (quiz generation, concept re-summary) ---
# mock | claude -- "mock" runs the whole pipeline deterministically without a key.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Temp scrap buffer safety valve ---
SCRAP_BUFFER_TTL_DAYS=7
SCRAP_BUFFER_MAX_ROWS=200

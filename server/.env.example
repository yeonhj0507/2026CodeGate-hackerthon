# 이 파일을 복사해 `.env` 로 만들고 값을 채우세요.  cp .env.example .env

# --- Database ---
# 운영/확정 스택: PostgreSQL (asyncpg 드라이버)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prober

# Postgres 없이 빠른 로컬 테스트를 원하면 아래처럼 sqlite 로 바꿔도 됩니다:
# DATABASE_URL=sqlite+aiosqlite:///./prober_dev.db

# --- JWT ---
# 운영에서는 반드시 길고 무작위한 값으로 교체 (예: openssl rand -hex 32)
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24h (데모 편의)

# --- App ---
APP_NAME=Prober Auth Service

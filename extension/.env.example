# .env.local로 복사해서 사용 (gitignore됨).
# true로 켜면 background/api.ts가 실제 서버 대신 canned Quiz[]를 반환한다.
# (T=3 §T3.4 — 서버 없이 observer→session→ui→background 체인 e2e 검증용)
VITE_MOCK_QUIZ=true

# true로 켜면 /scrap 실제 fetch 없이 즉시 성공 처리한다.
# (T=4 §T4.6 — 무서버 e2e에서 재시도 큐만 계속 쌓이는 것을 방지)
VITE_MOCK_SCRAP=true

# true로 켜면 팝업 로그인이 서버 없이 성공 처리된다(mock 토큰 저장).
# (Step 9 — VITE_MOCK_QUIZ/SCRAP와 짝. 아무 이메일 + 8자 이상 비밀번호로 로그인)
VITE_MOCK_AUTH=true
